{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vite/client"],
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/App.tsx",
    "src/main.tsx",
    "src/index.css",
    "src/vite-env.d.ts",
    "src/store/**/*.ts",
    "src/services/**/*.ts",
    "src/hooks/**/*.ts",
    "src/types/**/*.ts",
    "src/components/**/*.tsx",
    "src/routes/**/*.tsx",
    "tests/frontend/shell-smoke.test.ts",
    "vite.config.ts"
  ]
}
