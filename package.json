{
  "name": "testforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx tests/frontend/run-all-tests.ts",
    "test:t14:smoke": "node --import tsx tests/frontend/browser-replay-t14-smoke.ts",
    "test:t19:smoke": "node --import tsx tests/frontend/task-t19-smoke-report.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "TestForge - API and UI testing tool",
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tanstack/react-query": "^5.95.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
